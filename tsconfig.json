{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "target": "ES2022",
    "module": "ES2022"
  },
  "include": ["server/lib/**/*", "scripts/**/*"],
  "exclude": ["node_modules", "dist", "release", "dist-electron", "main.cjs", "preload.cjs", "src/**/*", "server/index.js", "eslint.config.js"]
}
