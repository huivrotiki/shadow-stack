{
  "agent": {
    "name": "Shadow",
    "provider": "ollama",
    "model": "qwen2.5-coder:3b"
  },
  "memory": {
    "enabled": true,
    "provider": "ollama",
    "embedding_model": "nomic-embed-text",
    "endpoint": "http://127.0.0.1:11434",
    "chunk_size": 500,
    "vector_db_path": "./memory/shadow_memory",
    "keep_alive_after_embed": 0,
    "compaction_threshold": 0.80
  },
  "skills": [
    ".agent/skills/memory-retrieve",
    ".agent/skills/memory-store"
  ],
  "ports": {
    "openclaw": 18789,
    "express": 3001,
    "bot": 4000,
    "litellm": 4001,
    "ollama": 11434,
    "dashboard": 5176
  }
}
