{
  "version": "1.0",
  "gateway": {
    "port": 18789,
    "host": "localhost"
  },
  "skills": [
    {
      "name": "browser-use",
      "path": "./skills/browser-use"
    }
  ],
  "knowledge": [
    {
      "name": "design-rules",
      "path": "./knowledge/DESIGN_RULES.md",
      "description": "Digital minimalism design rules for AI/SaaS/portfolio interfaces"
    }
  ],
  "providers": [
    {
      "id": "local-router",
      "name": "Shadow Stack Router",
      "type": "openai-compatible",
      "baseUrl": "http://localhost:3001/api",
      "model": "auto",
      "priority": 0,
      "costPerToken": 0,
      "maxTokens": 8192,
      "description": "Auto-routing via Express API: Ollama → OpenRouter fallback"
    },
    {
      "id": "ollama-local",
      "name": "Ollama 3B (local)",
      "type": "ollama",
      "baseUrl": "http://localhost:11434",
      "model": "qwen2.5:3b",
      "priority": 1,
      "costPerToken": 0,
      "maxTokens": 8192
    },
    {
      "id": "ollama-7b",
      "name": "Ollama 7B (local)",
      "type": "ollama",
      "baseUrl": "http://localhost:11434",
      "model": "qwen2.5:7b",
      "priority": 2,
      "costPerToken": 0,
      "maxTokens": 8192
    },
    {
      "id": "openrouter",
      "name": "OpenRouter",
      "type": "openrouter",
      "baseUrl": "https://openrouter.ai/api/v1",
      "model": "anthropic/claude-3-haiku",
      "priority": 3,
      "envKey": "OPENROUTER_API_KEY"
    },
    {
      "id": "claude",
      "name": "Claude Code",
      "type": "anthropic",
      "model": "claude-3-5-sonnet-20241022",
      "priority": 4,
      "envKey": "ANTHROPIC_API_KEY"
    }
  ],
  "routing": {
    "defaultProvider": "ollama-local",
    "fallbackChain": ["local-router", "ollama-local", "ollama-7b", "openrouter", "claude"],
    "rules": [
      { "pattern": "/premium", "provider": "claude" },
      { "pattern": "/code",    "provider": "claude" },
      { "pattern": "/fast",    "provider": "ollama-local" },
      { "pattern": "/cheap",   "provider": "ollama-local" }
    ]
  },
  "telegram": {
    "notifyOnStart": true,
    "notifyOnError": true,
    "notifyOnFallback": true
  }
}
