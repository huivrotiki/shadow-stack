{
  "version": "2.0",
  "gateway": {
    "port": 18789,
    "host": "localhost"
  },
  "skills": [
    { "name": "browser-use", "path": "./skills/browser-use" },
    { "name": "cascade", "path": "./skills/cascade" },
    { "name": "ralph-loop", "path": "./skills/ralph" },
    { "name": "memory", "path": "./skills/memory" },
    { "name": "safety", "path": "./skills/safety" },
    { "name": "devops", "path": "./skills/devops" },
    { "name": "kb", "path": "./skills/kb" }
  ],
  "knowledge": [
    {
      "name": "design-rules",
      "path": "./knowledge/DESIGN_RULES.md",
      "description": "Digital minimalism design rules for AI/SaaS/portfolio interfaces"
    }
  ],
  "providers": [
    {
      "id": "gemini-browser",
      "name": "Gemini (Browser CDP)",
      "type": "shadow-router",
      "baseUrl": "http://localhost:3002",
      "target": "gemini",
      "priority": 0,
      "costPerToken": 0,
      "description": "Gemini via Chrome CDP — free, no API limits"
    },
    {
      "id": "groq-browser",
      "name": "Groq (Browser CDP)",
      "type": "shadow-router",
      "baseUrl": "http://localhost:3002",
      "target": "groq",
      "priority": 1,
      "costPerToken": 0,
      "description": "Groq via Chrome CDP — free, no API limits"
    },
    {
      "id": "manus-browser",
      "name": "Manus (Browser CDP)",
      "type": "shadow-router",
      "baseUrl": "http://localhost:3002",
      "target": "manus",
      "priority": 2,
      "costPerToken": 0,
      "description": "Manus AI via Chrome CDP"
    },
    {
      "id": "perplexity-comet",
      "name": "Perplexity (Comet)",
      "type": "shadow-router",
      "baseUrl": "http://localhost:3002",
      "target": "perplexity",
      "priority": 3,
      "costPerToken": 0,
      "description": "Perplexity via Comet browser — search + citations"
    },
    {
      "id": "openrouter",
      "name": "OpenRouter (Free Tier)",
      "type": "openrouter",
      "baseUrl": "https://openrouter.ai/api/v1",
      "model": "deepseek/deepseek-r1:free",
      "priority": 4,
      "envKey": "OPENROUTER_API_KEY",
      "description": "OpenRouter free models: DeepSeek R1, Step-3.5, Minimax"
    },
    {
      "id": "antigravity",
      "name": "Antigravity Copilot (CDP)",
      "type": "shadow-router",
      "baseUrl": "http://localhost:3002",
      "target": "antigravity",
      "priority": 5,
      "costPerToken": 0,
      "description": "Antigravity via Chrome CDP"
    },
    {
      "id": "copilot-browser",
      "name": "Microsoft Copilot (Browser)",
      "type": "shadow-router",
      "baseUrl": "http://localhost:3002",
      "target": "copilot",
      "priority": 6,
      "costPerToken": 0,
      "description": "Microsoft Copilot via Chrome CDP"
    },
    {
      "id": "perplexity-chat",
      "name": "Perplexity Chat (Comet)",
      "type": "shadow-router",
      "baseUrl": "http://localhost:3002",
      "target": "perplexity2",
      "priority": 7,
      "costPerToken": 0,
      "description": "Perplexity chat mode via Comet"
    },
    {
      "id": "telegram-bots",
      "name": "Telegram Bot Relay",
      "type": "telegram-relay",
      "bots": ["@chatgpt_gidbot", "@deepseek_gidbot"],
      "priority": 8,
      "costPerToken": 0,
      "description": "Telegram group bot escalation"
    },
    {
      "id": "ollama-local",
      "name": "Ollama 3B (Local)",
      "type": "ollama",
      "baseUrl": "http://localhost:11434",
      "model": "qwen2.5-coder:3b",
      "priority": 9,
      "costPerToken": 0,
      "maxTokens": 4096,
      "num_ctx": 4096,
      "keep_alive": 0,
      "description": "Local Ollama — last resort, uses RAM. keep_alive:0 = unload immediately after use (M1 8GB safety)"
    }
  ],
  "routing": {
    "defaultProvider": "gemini-browser",
    "quotaThreshold": 0.90,
    "fallbackChain": [
      "gemini-browser",
      "groq-browser",
      "manus-browser",
      "perplexity-comet",
      "openrouter",
      "antigravity",
      "copilot-browser",
      "perplexity-chat",
      "telegram-bots",
      "ollama-local"
    ],
    "presets": {
      "free_coder": {
        "primary": "ollama-local",
        "fallback": "groq-browser",
        "description": "Максимально дешевый кодинг (Ollama → Groq)"
      },
      "smart_research": {
        "primary": "perplexity-comet",
        "fallback": "gemini-browser",
        "description": "Глубокий ресерч с цитатами (Perplexity → Gemini)"
      },
      "pro_deploy": {
        "primary": "gemini-browser",
        "fallback": "openrouter",
        "description": "Продакшн-качество (Gemini → OpenRouter)"
      },
      "ui_vibe": {
        "primary": "gemini-browser",
        "fallback": "copilot-browser",
        "description": "UI/UX дизайн (Gemini → Copilot)"
      },
      "fast_local": {
        "primary": "ollama-local",
        "fallback": "ollama-local",
        "description": "Только локально, без сети"
      }
    },
    "rules": [
      {
        "pattern": "/fast",
        "provider": "gemini-browser",
        "description": "Fastest browser response"
      },
      {
        "pattern": "/code",
        "provider": "groq-browser",
        "description": "Code-optimized via Groq"
      },
      {
        "pattern": "/research",
        "provider": "perplexity-comet",
        "description": "Search + citations via Perplexity"
      },
      {
        "pattern": "/cheap",
        "provider": "ollama-local",
        "description": "Zero cost, zero network"
      },
      {
        "pattern": "/premium",
        "provider": "gemini-browser",
        "description": "Best free quality via Gemini"
      },
      {
        "pattern": "/preset_coder",
        "preset": "free_coder",
        "description": "Активировать пресет: бесплатный кодинг"
      },
      {
        "pattern": "/preset_research",
        "preset": "smart_research",
        "description": "Активировать пресет: умный ресерч"
      },
      {
        "pattern": "/preset_deploy",
        "preset": "pro_deploy",
        "description": "Активировать пресет: продакшн"
      }
    ]
  },
  "telegram": {
    "notifyOnStart": true,
    "notifyOnError": true,
    "notifyOnFallback": true
  }
}
