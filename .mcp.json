{
  "mcpServers": {
    "supermemory-mcp": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://mcp.supermemory.ai/mcp"],
      "env": {}
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    }
  }
}
