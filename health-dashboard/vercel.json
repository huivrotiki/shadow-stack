{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "mermaid.min.js", "use": "@vercel/static" },
    { "src": "*.md", "use": "@vercel/static" },
    { "src": "api/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/mermaid.min.js", "dest": "/mermaid.min.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
