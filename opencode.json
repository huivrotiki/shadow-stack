      "npm": "@ai-sdk/openai-compatible",
      "name": "Shadow (US-West, 113 models)",
      "options": {
        "baseURL": "http://localhost:20133/v1",
        "apiKey": "sk-shadow-prod-local"
      },
      "models": {
        "auto": { "name": "Auto Route" },
        "gr-llama70b": { "name": "Groq Llama 70B" },
        "gr-qwen3-32b": { "name": "Groq Qwen3 32B" },
        "cb-llama70b": { "name": "Cerebras Llama 70B" },
        "gem-2.5-flash": { "name": "Gemini 2.5 Flash" },
        "ms-small": { "name": "Mistral Small" },
        "or-nemotron": { "name": "Nemotron Nano" },
        "sn-llama70b": { "name": "SambaNova Llama 70B" },
        "or-step-flash": { "name": "Step 3.5 Flash" },
        "hf-llama8b": { "name": "HuggingFace Llama 8B" },
        "nv-llama70b": { "name": "NVIDIA NIM Llama 70B" },
