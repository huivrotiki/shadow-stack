        "kr/claude-haiku-4.5": { "name": "Claude Haiku 4.5 (free)" }
      }
    },
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (Local)",
      "options": {
        "baseURL": "http://localhost:11434/v1",
        "apiKey": "ollama"
      },
      "models": {
        "qwen2.5-coder:3b": { "name": "Qwen 2.5 Coder 3B" },
        "llama3.2:3b": { "name": "Llama 3.2 3B" },
        "qwen2.5:7b": { "name": "Qwen 2.5 7B" }
