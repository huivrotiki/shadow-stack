    },
    "shadowAlt": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Shadow Alt (EU-West, 99 models)",
      "options": {
        "baseURL": "http://localhost:20134/v1",
        "apiKey": "sk-shadow-alt-local"
      },
      "models": {
        "auto": { "name": "Auto Route" },
        "gr-llama70b": { "name": "Groq Llama 70B" },
        "gr-llama8b": { "name": "Groq Llama 8B" },
        "gr-qwen3": { "name": "Groq Qwen3 32B" },
        "cb-llama70b": { "name": "Cerebras Llama 70B" },
        "gem-2.5-flash": { "name": "Gemini 2.5 Flash" },
        "ms-small": { "name": "Mistral Small" },
        "ms-medium": { "name": "Mistral Medium" },
        "or-nemotron": { "name": "Nemotron Nano" },
        "or-nemotron120": { "name": "Nemotron 120B" },
        "or-llama70b": { "name": "Llama 3.3 70B" },
        "or-llama3b": { "name": "Llama 3.2 3B" },
        "or-gemma27b": { "name": "Gemma 3 27B" },
        "hf-qwen72b": { "name": "HuggingFace Qwen 72B" },
        "hf-llama70b": { "name": "HuggingFace Llama 70B" },
        "ds-v3": { "name": "DeepSeek V3" },
        "ds-r1": { "name": "DeepSeek R1" },
        "ol-qwen2.5": { "name": "Ollama Qwen 2.5 7B" }
      }
    },
    "omniroute": {
      "npm": "@ai-sdk/openai-compatible",
