{
  "$schema": "https://opencode.ai/config.json",

  // ── ОСНОВНАЯ МОДЕЛЬ ───────────────────────────────
  "model": "shadow-ultimate-cascade/or-qwen3.6",
  "small_model": "shadow-ultimate-cascade/ol-qwen2.5-coder",
  "default_agent": "main",

  // ── ПРОВАЙДЕРЫ ────────────────────────────────────
  "provider": {
    "shadow-ultimate-cascade": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Shadow Ultimate Cascade (31 models)",
      "options": {
        "baseURL": "http://localhost:20129/v1",
        "apiKey": "{env:FREE_PROXY_API_KEY}"
      },
      "models": {
        "or-qwen3.6": { "name": "Qwen 3.6 Plus (free, primary)" },
        "or-nemotron": { "name": "Nemotron Nano (free)" },
        "or-trinity": { "name": "Trinity Large (free)" },
        "or-minimax": { "name": "MiniMax M2.5 (free)" },
        "or-step-flash": { "name": "Step 3.5 Flash (free)" },
        "zen-qwen3.6": { "name": "Zen Qwen 3.6 (opencode.ai)" },
        "zen-nemotron": { "name": "Zen Nemotron (opencode.ai)" },
        "zen-big-pickle": { "name": "Zen Big Pickle (stealth)" },
        "zen-mimo-pro": { "name": "Zen MiMo V2 Pro (free)" },
        "zen-mimo-omni": { "name": "Zen MiMo V2 Omni (free)" },
        "groq-llama-70b": { "name": "Groq Llama 70B (fast)" },
        "gemini-flash": { "name": "Gemini 2.0 Flash" },
        "gemini-flash-lite": { "name": "Gemini 2.0 Flash Lite" },
        "gemini-pro": { "name": "Gemini 2.5 Pro" },
        "hf-deepseek-v3": { "name": "DeepSeek V3 (HuggingFace)" },
        "hf-deepseek-r1": { "name": "DeepSeek R1 (HuggingFace)" },
        "copilot-gpt-5.4": { "name": "Copilot GPT-5.4" },
        "copilot-gpt-5.4-mini": { "name": "Copilot GPT-5.4 mini (fast)" },
        "copilot-gpt-5.3-codex": { "name": "Copilot GPT-5.3 Codex (code)" },
        "copilot-sonnet-4.6": { "name": "Copilot Claude Sonnet 4.6" },
        "copilot-haiku-4.5": { "name": "Copilot Claude Haiku 4.5 (fast)" },
        "copilot-opus-4.6": { "name": "Copilot Claude Opus 4.6" },
        "copilot-gemini-2.5-pro": { "name": "Copilot Gemini 2.5 Pro" },
        "copilot-grok-code-fast-1": { "name": "Copilot Grok Code Fast 1" },
        "mistral-small": { "name": "Mistral Small" },
        "ol-qwen2.5-coder": { "name": "Ollama Qwen Coder (local)" },
        "ol-qwen2.5": { "name": "Ollama Qwen 2.5 (local)" },
        "ol-llama3.2": { "name": "Ollama Llama 3.2 (local)" },
        "ol-deepseek-v3.1": { "name": "Ollama DeepSeek V3.1 (local)" },
        "ol-qwen3-coder": { "name": "Ollama Qwen3 Coder (local)" },
        "ol-gpt-oss": { "name": "Ollama GPT-OSS (local)" }
      }
    },
    "anthropic": {
      "options": {
        "apiKey": "{env:ANTHROPIC_API_KEY}",
        "timeout": 600000,
        "setCacheKey": true
      }
    },
    "google": {
      "options": {
        "apiKey": "{env:GOOGLE_API_KEY}",
        "timeout": 600000
      }
    },
    "openai": {
      "options": {
        "apiKey": "{env:OPENAI_API_KEY}",
        "timeout": 600000
      }
    },
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (Local)",
      "options": {
        "baseURL": "http://localhost:11434/v1",
        "apiKey": "ollama"
      },
      "models": {
        "qwen2.5-coder:3b": { "name": "Qwen 2.5 Coder 3B" },
        "llama3.2:3b": { "name": "Llama 3.2 3B" },
        "qwen2.5:7b": { "name": "Qwen 2.5 7B" }
      }
    },
    "openrouter": {
      "options": {
        "apiKey": "{env:OPENROUTER_API_KEY}"
      }
    },
    "groq": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Groq",
      "options": {
        "baseURL": "https://api.groq.com/openai/v1",
        "apiKey": "{env:GROQ_API_KEY}"
      },
      "models": {
        "llama-3.3-70b-versatile": { "name": "Llama 3.3 70B" }
      }
    },
    "opencode": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenCode Zen (Free Models)",
      "options": {
        "baseURL": "https://opencode.ai/zen/v1"
      },
      "models": {
        "qwen3.6-plus-free": { "name": "Qwen 3.6 Plus (FREE)" },
        "nemotron-3-super-free": { "name": "Nemotron 3 Super (FREE)" },
        "big-pickle": { "name": "Big Pickle (FREE)" },
        "mimo-v2-pro-free": { "name": "MiMo V2 Pro (FREE)" },
        "mimo-v2-omni-free": { "name": "MiMo V2 Omni (FREE)" },
        "minimax-m2.5-free": { "name": "MiniMax M2.5 (FREE)" }
      }
    },
    "copilot": {
      "options": {
        "baseURL": "https://api.githubcopilot.com"
      }
    }
  },

  // ── MCP СЕРВЕРЫ ───────────────────────────────────
  "mcp": {
    "vercel": {
      "type": "remote",
      "url": "https://mcp.vercel.com",
      "enabled": true
    },
    "supermemory": {
      "type": "remote",
      "url": "https://api.supermemory.ai/mcp",
      "enabled": true
    }
  },

  // ── ИНСТРУМЕНТЫ ───────────────────────────────────
  "tools": {
    "write": true,
    "edit":  true,
    "bash":  true
  },

  // ── РАЗРЕШЕНИЯ ────────────────────────────────────
  // "ask" = спрашивать перед выполнением (безопаснее для прода)
  "permission": {
    "bash": "ask",
    "edit": "allow",
    "write": "allow"
  },

  // ── КОНТЕКСТ ─────────────────────────────────────
  "instructions": [
    "AGENTS.md",
    "CLAUDE.md"
  ],

  // ── COMPACTION (важно для длинных сессий) ─────────
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 15000
  },

  // ── FILE WATCHER ──────────────────────────────────
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      ".git/**",
      "memory/**",
      ".next/**"
    ]
  },

  // ── КАСТОМНЫЕ КОМАНДЬ ─────────────────────────────
  "command": {
    "next": {
      "description": "Следующий незакрытый шаг из чеклиста",
      "template": "Прочитай AGENTS.md и CLAUDE.md. Найди первый [ ] в чеклисте. Выполни только его. Запусти тест. Отчёт: что сделал + результат теста + следующий шаг.",
      "agent": "build",
      "model": "anthropic/claude-sonnet-4-5"
    },
    "block": {
      "description": "Выполнить блок N: /block N",
      "template": "Прочитай AGENTS.md и CLAUDE.md. Реализуй БЛОК $ARGUMENTS полностью. После каждого файла запусти тест. Не переходи дальше пока тест не зелёный. В конце: ✅ что сделано, git commit.",
      "agent": "build"
    },
    "test": {
      "description": "Smoke тест всей системы",
      "template": "Запусти все тесты из раздела ТЕСТИРОВАНИЕ в CLAUDE.md. Формат: команда → результат → ✅/❌. Итог одним сообщением.",
      "agent": "build",
      "model": "anthropic/claude-haiku-4-5"
    },
    "fix": {
      "description": "Починить баг: /fix описание",
      "template": "Баг: $ARGUMENTS\n1. Найди причину в коде\n2. Исправь минимальным изменением\n3. Запусти тест\n4. git commit: fix: $ARGUMENTS\n5. Отчёт",
      "agent": "build"
    },
    "deploy": {
      "description": "Деплой на Vercel",
      "template": "Выполни: vercel deploy --prod. Покажи URL и статус деплоя.",
      "agent": "build"
    },
    "status": {
      "description": "Статус проекта из CLAUDE.md",
      "template": "Прочитай CLAUDE.md. Покажи только чеклист с ✅/[ ]. Компактно, без кода.",
      "agent": "build",
      "model": "anthropic/claude-haiku-4-5"
    },
    "commit": {
      "description": "Закоммитить текущий прогресс",
      "template": "Посмотри git status и git diff. Сделай коммит с осмысленным сообщением в формате feat/fix/chore(scope): description. Покажи что закоммичено.",
      "agent": "build",
      "model": "anthropic/claude-haiku-4-5"
    }
  },

  // ── АГЕНТЫ ────────────────────────────────────────
  "agent": {
    "shadow-planner": {
      "description": "Планировщик задач Shadow Stack",
      "model": "anthropic/claude-sonnet-4-5",
      "prompt": "Ты планировщик Shadow Stack. Разбивай задачи на атомарные шаги. Учитывай RAM RULES (M1 8GB). Используй только sequential выполнение. Возвращай нумерованный список шагов.",
      "tools": {
        "write": false,
        "edit":  false,
        "bash":  false
      }
    },
    "shadow-reviewer": {
      "description": "Code reviewer — только читает, не меняет",
      "model": "google/gemini-2.0-flash",
      "prompt": "Ты code reviewer. Проверяй на: RAM RULES соблюдение, for...of вместо Promise.all, try/catch на внешних вызовах, CJS в server/lib/, ESM в pages/api/. Не вноси изменений — только отчёт.",
      "tools": {
        "write": false,
        "edit":  false
      }
    }
  },

  // ── ФОРМАТТЕРЫ ────────────────────────────────────
  "formatter": {
    "prettier": {
      "disabled": false
    }
  },

  // ── ОБНОВЛЕНИЯ ────────────────────────────────────
  "autoupdate": true,
  "share": "manual"
}