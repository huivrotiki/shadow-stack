{
  "name": "shadow-stack-widget",
  "productName": "Shadow Stack Widget",
  "private": true,
  "version": "3.2.0",
  "main": "main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron": "wait-on --timeout 30000 http://127.0.0.1:5175 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5175 node_modules/.bin/electron .",
    "start": "concurrently --names \"vite,electron\" --prefix-colors \"cyan,yellow\" \"npm run dev\" \"npm run electron\"",
    "headless": "node main.cjs",
    "kill-port": "lsof -ti:5175 | xargs kill -9 2>/dev/null || true",
    "preview": "vite preview",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "bot:dev": "node bot/opencode-telegram-bridge.cjs",
    "bot:start": "node bot/opencode-telegram-bridge.cjs",
    "bot:step11": "cd projects/telegram-bot && npm start",
    "api": "node server/index.js",
    "api:dev": "node --watch server/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ server/ --max-warnings 0",
    "test": "vitest run",
    "smoke": "node scripts/smoke-test.cjs",
    "omni": "ts-node server/omni-endpoint.ts",
    "omni:dev": "nodemon --exec ts-node server/omni-endpoint.ts",
    "validate-docs": "bash scripts/validate-docs-index.sh"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.50",
    "@ai-sdk/openai-compatible": "^2.0.38",
    "@anthropic-ai/sdk": "^0.82.0",
    "@supabase/supabase-js": "^2.100.1",
    "@supermemory/tools": "^1.4.1",
    "ai": "^6.0.146",
    "chart.js": "^4.4.1",
    "express": "^4.21.0",
    "lucide-react": "^0.468.0",
    "node-telegram-bot-api": "^0.67.0",
    "react": "^19.2.4",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^19.2.4",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@ai-sdk/google": "^3.0.58",
    "@eslint/js": "^9.0.0",
    "@openrouter/ai-sdk-provider": "^2.3.3",
    "@tailwindcss/postcss": "^4.2.2",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "chalk": "^5.6.2",
    "cli-progress": "^3.12.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.29.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "inquirer": "^13.3.2",
    "nodemon": "^3.1.14",
    "playwright": "^1.59.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.2",
    "wait-on": "^9.0.4",
    "yamljs": "^0.3.0"
  },
  "overrides": {
    "@xmldom/xmldom": "^0.8.12",
    "form-data@<2.5.4": "2.5.4",
    "tough-cookie@<4.1.3": "^4.1.3",
    "qs@<6.14.1": "^6.14.1",
    "request": "npm:@cypress/request@^3.0.10",
    "lodash": "^4.18.1"
  },
  "build": {
    "appId": "com.shadowstack.widget",
    "productName": "Shadow Stack Widget",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "main.cjs",
      "preload.cjs",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dir",
        "dmg"
      ]
    }
  }
}
